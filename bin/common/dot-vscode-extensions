#!/bin/bash

set -euo pipefail

DOTFILES="$HOME/Repos/dotfiles"

if ! command -v code &>/dev/null; then
  echo "code is not installed or not on PATH. Aborting."
  exit 1
fi

[[ "${DOT_VARIANT:-}" != "personal" && "${DOT_VARIANT:-}" != "corp" ]] && echo "Invalid variant '${DOT_VARIANT:-}'. Aborting." && exit 1

wanted=$(printf '%s\n' "$(cat "$DOTFILES/vscode/extensions")" "$(cat "$DOTFILES/vscode/extensions.$DOT_VARIANT")" | grep -v '^$')

while IFS= read -r ext; do
  echo "Installing VS Code extension: $ext"
  code --install-extension "$ext" --force
done <<< "$wanted"

while IFS= read -r ext; do
  if ! grep -qi "^${ext}$" <<< "$wanted"; then
    echo "Uninstalling VS Code extension: $ext"
    code --uninstall-extension "$ext"
  fi
done < <(code --list-extensions)
