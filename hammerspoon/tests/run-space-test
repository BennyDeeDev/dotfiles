#!/bin/bash

set -e

LOG="/tmp/space_test_$(date +%Y%m%d_%H%M%S).log"

SCRIPT="$(cd "$(dirname "$0")" && pwd)/space_test.lua"

hs -c "SPACE_TEST_LOG='$LOG'; LOOPS=15; SPACES={1,3}; dofile('$SCRIPT')"

echo "Waiting for test to finish..."
TIMEOUT=60
ELAPSED=0
until grep -q "Result:" "$LOG" 2>/dev/null; do
    sleep 0.5
    ELAPSED=$((ELAPSED + 1))
    if [[ $ELAPSED -ge $((TIMEOUT * 2)) ]]; then
        echo "Timed out after ${TIMEOUT}s — log may be incomplete: $LOG"
        exit 1
    fi
done

while IFS= read -r line; do
    case "$line" in
        *"[PASS]"*) printf "\033[32m%s\033[0m\n" "$line" ;;
        *"[FAIL]"*) printf "\033[31m%s\033[0m\n" "$line" ;;
        *)          echo "$line" ;;
    esac
done < "$LOG"
