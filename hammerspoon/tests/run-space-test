#!/bin/bash

set -e

LOG="/tmp/space_test_$(date +%Y%m%d_%H%M%S).log"
SCRIPT="$(cd "$(dirname "$0")" && pwd)/space_test.lua"

# Set LOAD to a fraction of CPU cores to stress during the test, e.g: LOAD=0.5 ./run-space-test
LOAD_PIDS=()
if [[ "${LOAD:-0}" != "0" ]]; then
    CORES=$(sysctl -n hw.logicalcpu)
    WORKERS=$(( $(echo "$CORES * ${LOAD}" | bc | awk '{print int($1+0.5)}') ))
    [[ $WORKERS -lt 1 ]] && WORKERS=1
    echo "Stressing ${WORKERS}/${CORES} CPU cores during test..."
    for ((i = 0; i < WORKERS; i++)); do
        yes > /dev/null &
        LOAD_PIDS+=($!)
    done
fi

cleanup() {
    for pid in "${LOAD_PIDS[@]}"; do
        kill "$pid" 2>/dev/null
    done
}
trap cleanup EXIT

hs -c "SPACE_TEST_LOG='$LOG'; LOOPS=5; SPACES={1,3}; dofile('$SCRIPT')"

echo "Waiting for test to finish..."
TIMEOUT=120
ELAPSED=0
until grep -q "Result:" "$LOG" 2>/dev/null; do
    sleep 0.5
    ELAPSED=$((ELAPSED + 1))
    if [[ $ELAPSED -ge $((TIMEOUT * 2)) ]]; then
        echo "Timed out after ${TIMEOUT}s — log may be incomplete: $LOG"
        exit 1
    fi
done

while IFS= read -r line; do
    case "$line" in
        *"[PASS]"*) printf "\033[32m%s\033[0m\n" "$line" ;;
        *"[FAIL]"*) printf "\033[31m%s\033[0m\n" "$line" ;;
        *)          echo "$line" ;;
    esac
done < "$LOG"
